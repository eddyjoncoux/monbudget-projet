{% extends 'base.html.twig' %}

{% block title %}Category{% endblock %}

{% block body %}
<div class="page-container">
    <h1>Category</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ category.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ category.name }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-primary">Editer</a>

        {{ include('category/_delete_form.html.twig') }}
    
    <a href="{{ path('app_category_index') }}" class="btn btn-success">Retour aux catégories</a>
</div>
{% endblock %}
