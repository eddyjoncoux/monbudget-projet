{% extends 'base.html.twig' %}

{% block title %}Category index{% endblock %}

{% block body %}
<div class="page-container">
    <h1>Page des catégories</h1>
        <div class="btn-navigation">
            <a href="{{ path('app_transaction_new') }}" class="btn btn-primary">➕ Ajouter une nouvelle transaction</a>
            <br>
            <a href="{{ path('app_category_new') }}" class="btn btn-primary">➕ Ajouter une nouvelle catégorie</a>
            <br>
            <a href="{{ path('app_user_dashboard')}}" class="btn btn-success">↩️Revenir au Dashboard</a>
        </div>

    <div class="mes-transactions">
        <div class="transactions-container">
            <table class="transactions-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for category in categories %}
                    <tr>
                        <td>{{ category.name }}</td>
                        <td>
                            <a href="{{ path('app_category_show', {'id': category.id}) }}" class="btn-icon" title="Voir">👁️</a>
                            <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn-icon" title="Modifier">✏️</a>
                            <a href="{{ path('app_category_delete', {'id': category.id}) }}" class="btn-icon btn-delete" title="Supprimer">🗑️</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Aucune catégorie n'a été créée</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
    </div>
</div>
{% endblock %}
