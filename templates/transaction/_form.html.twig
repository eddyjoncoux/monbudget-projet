<div class="form-withdrawal">
{{ form_start(form) }}
    <div class="form-group">
        {{ form_label(form.amount, 'Montant') }}
        {{ form_widget(form.amount, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
        {{ form_help(form.amount) }}
        {{ form_errors(form.amount) }}
    </div>
    <div class="form-group">
        {{ form_label(form.date, 'Date') }}
        {{ form_widget(form.date, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
        {{ form_help(form.date) }}
        {{ form_errors(form.date) }}
    </div>
    <div class="form-group">
        {{ form_label(form.description, 'Description') }}
        {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
        {{ form_help(form.description) }}
        {{ form_errors(form.description) }}
    </div>
      <div class="form-group">
        {{ form_label(form.type, 'Type') }}
        {{ form_widget(form.type) }}
        {{ form_help(form.type) }}
        {{ form_errors(form.type) }}
    </div>
      <div class="form-group">
        {{ form_label(form.category) }}
        <div class="category-input-group">
            {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
            <div class="category-add-section">
                <input type="text" id="new_category_name" placeholder="Ou créer une nouvelle catégorie..." class="form-control" style="margin-top: 0.5rem;">
                <button type="button" id="add_category_btn" class="btn btn-secondary" style="margin-top: 0.5rem;">➕ Ajouter</button>
            </div>
        </div>
        {{ form_help(form.category) }}
        {{ form_errors(form.category) }}
    </div>
    <div class="form-actions">
        <button class="btn btn-primary">{{ button_label|default('Sauvegarder') }}</button>
    </div>
{{ form_end(form) }}

<script>
document.addEventListener('DOMContentLoaded', function() {
    const addCategoryBtn = document.getElementById('add_category_btn');
    const newCategoryInput = document.getElementById('new_category_name');
    const categorySelect = document.getElementById('{{ form.category.vars.id }}');

    addCategoryBtn.addEventListener('click', async function() {
        const categoryName = newCategoryInput.value.trim();

        if (!categoryName) {
            alert('Veuillez saisir un nom de catégorie');
            return;
        }

        try {
            const response = await fetch('{{ path('app_category_api_create') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-CSRF-Token': '{{ csrf_token('category_create') }}'
                },
                body: JSON.stringify({ name: categoryName })
            });

            const data = await response.json();

            if (data.success) {
                // Ajouter la nouvelle catégorie au select
                const option = new Option(data.category.name, data.category.id);
                categorySelect.add(option);
                categorySelect.value = data.category.id;

                // Vider le champ et afficher un message de succès
                newCategoryInput.value = '';
                alert('Catégorie "' + data.category.name + '" ajoutée avec succès !');

                // Masquer la section d'ajout après succès
                document.querySelector('.category-add-section').style.display = 'none';
            } else {
                alert('Erreur: ' + data.message);
            }
        } catch (error) {
            console.error('Erreur:', error);
            alert('Une erreur est survenue lors de la création de la catégorie');
        }
    });

    // Afficher/masquer la section d'ajout selon la sélection
    categorySelect.addEventListener('change', function() {
        const addSection = document.querySelector('.category-add-section');
        if (this.value === '') {
            addSection.style.display = 'block';
        } else {
            addSection.style.display = 'none';
        }
    });

    // Masquer initialement la section d'ajout si une catégorie est déjà sélectionnée
    if (categorySelect.value !== '') {
        document.querySelector('.category-add-section').style.display = 'none';
    }
});
</script>
</div>
