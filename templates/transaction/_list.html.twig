
<div>
    <div>
        {% set total = 0 %}
        {% for dateGroup in itemsByDate %}
            {% for item in dateGroup.items %}
                {% if item.type == 'transaction' %}
                    {% set total = total + item.data.amount %}
                {% endif %}
            {% endfor %}
        {% endfor %}
        <p>{{ total }} €</p>
    </div>
    {% if itemsByDate is not empty %}
    <div class="transactions-container">
        <table class="transactions-table">
            <thead>
                <tr>
                    <th>Description</th>
                    <th>Montant</th>
                    <th>Catégorie</th>
                </tr>
            </thead>
            <tbody>
                {% for dateGroup in itemsByDate %}
                    <tr class="date-separator">
                        <td colspan="4" class="date-header">
                            📅 {{ dateGroup.date|date('d/m/Y') }}
                        </td>
                    </tr>
                    {% for item in dateGroup.items %}
                        {% if item.type == 'transaction' %}
                            <tr class="transaction-item {{ item.data.type.value|lower }}">
                                <td class="transaction-description">{{ item.data.description }}</td>
                                <td class="transaction-amount">
                                    {{ item.data.amount }}€
                                </td>
                                <td>
                                    {{ item.data.category.name }}
                                </td>
                            </tr>
                        {% endif %}
                    {% endfor %}
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
        <p class="no-transactions">Aucune transaction pour le moment.</p>
    {% endif %}