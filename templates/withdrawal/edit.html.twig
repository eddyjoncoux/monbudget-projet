{% extends 'base.html.twig' %}

{% block title %}Modifier le prélèvement{% endblock %}

{% block body %}
<div class="page-container">
    <h1>Modifier le prélèvement</h1>
    
    <div class="form-withdrawal-container">
        {{ form_start(form, {'attr': {'class': 'form-withdrawal'}}) }}
            
            <div class="form-group">
                {{ form_label(form.amount, 'Montant') }}
                {{ form_widget(form.amount, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
                {{ form_help(form.amount) }}
                {{ form_errors(form.amount) }}
            </div>

            <div class="form-group">
                {{ form_label(form.description, 'Description') }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                {{ form_help(form.description) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.frequency, 'Fréquence') }}
                    {{ form_widget(form.frequency, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
                    {{ form_errors(form.frequency) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.category, 'Catégorie') }}
                    {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.category) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.startDate, 'Date de début') }}
                    {{ form_widget(form.startDate, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
                    {{ form_help(form.startDate) }}
                    {{ form_errors(form.startDate) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.nextWithdrawalDate, 'Prochain prélèvement') }}
                    {{ form_widget(form.nextWithdrawalDate, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
                    {{ form_errors(form.nextWithdrawalDate) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.endDate, 'Date de fin') }}
                {{ form_widget(form.endDate, {'attr': {'class': 'form-control'}}) }}
                {{ form_help(form.endDate) }}
                {{ form_errors(form.endDate) }}
            </div>

            <div class="form-group form-check">
                {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
                {{ form_label(form.isActive, 'Prélèvement actif', {'label_attr': {'class': 'form-check-label'}}) }}
                {{ form_help(form.isActive) }}
                {{ form_errors(form.isActive) }}
            </div>

            <div class="info-box">
                <p><strong>Créé le :</strong> {{ withdrawal.createdAt|date('d/m/Y à H:i') }}</p>
                {% if withdrawal.updatedAt %}
                    <p><strong>Modifié le :</strong> {{ withdrawal.updatedAt|date('d/m/Y à H:i') }}</p>
                {% endif %}
                {% if withdrawal.lastWithdrawalDate %}
                    <p><strong>Dernier prélèvement :</strong> {{ withdrawal.lastWithdrawalDate|date('d/m/Y') }}</p>
                {% endif %}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">✅ Modifier le prélèvement</button>
                <a href="{{ path('app_withdrawal_show', {'id': withdrawal.id}) }}" class="btn btn-secondary">👁️ Voir</a>
                <a href="{{ path('app_withdrawal_index') }}" class="btn btn-secondary">↩️ Retour</a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
