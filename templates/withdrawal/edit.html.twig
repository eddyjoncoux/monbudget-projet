{% extends 'base.html.twig' %}

{% block title %}Modifier le prélèvement{% endblock %}

{% block body %}
<div class="page-container">
    <h1>Modifier le prélèvement</h1>
    
    <div class="form-withdrawal-container">
        {{ form_start(form, {'attr': {'class': 'form-withdrawal'}}) }}
            
            <div class="form-group">
                {{ form_label(form.amount, 'Montant') }}
                {{ form_widget(form.amount, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
                {{ form_help(form.amount) }}
                {{ form_errors(form.amount) }}
            </div>

            <div class="form-group">
                {{ form_label(form.description, 'Description') }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                {{ form_help(form.description) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.frequency, 'Fréquence') }}
                    {{ form_widget(form.frequency, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
                    {{ form_errors(form.frequency) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.category, 'Catégorie') }}
                    <div class="category-input-group">
                        {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
                        <div class="category-add-section">
                            <input type="text" id="new_category_name" placeholder="Ou créer une nouvelle catégorie..." class="form-control">
                            <button type="button" id="add_category_btn" class="btn btn-secondary">➕ Ajouter</button>
                        </div>
                    </div>
                    {{ form_errors(form.category) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.dayOfMonth, 'Jour du mois') }}
                    {{ form_widget(form.dayOfMonth, {'attr': {'class': 'form-control', 'required': 'required'}}) }}
                    {{ form_help(form.dayOfMonth) }}
                    {{ form_errors(form.dayOfMonth) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.endDate, 'Date de fin (optionnel)') }}
                    {{ form_widget(form.endDate, {'attr': {'class': 'form-control'}}) }}
                    {{ form_help(form.endDate) }}
                    {{ form_errors(form.endDate) }}
                </div>
            </div>
            </div>

            <div class="form-group form-check">
                {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
                {{ form_label(form.isActive, 'Prélèvement actif', {'label_attr': {'class': 'form-check-label'}}) }}
                {{ form_help(form.isActive) }}
                {{ form_errors(form.isActive) }}
            </div>

            <div class="info-box">
                <p><strong>Créé le :</strong> {{ withdrawal.createdAt|date('d/m/Y à H:i') }}</p>
                {% if withdrawal.updatedAt %}
                    <p><strong>Modifié le :</strong> {{ withdrawal.updatedAt|date('d/m/Y à H:i') }}</p>
                {% endif %}
                {% if withdrawal.lastWithdrawalDate %}
                    <p><strong>Dernier prélèvement :</strong> {{ withdrawal.lastWithdrawalDate|date('d/m/Y') }}</p>
                {% endif %}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">✅ Modifier le prélèvement</button>
                <a href="{{ path('app_withdrawal_show', {'id': withdrawal.id}) }}" class="btn btn-secondary">👁️ Voir</a>
                <a href="{{ path('app_withdrawal_index') }}" class="btn btn-secondary">↩️ Retour</a>
            </div>

        {{ form_end(form) }}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const addCategoryBtn = document.getElementById('add_category_btn');
    const newCategoryInput = document.getElementById('new_category_name');
    const categorySelect = document.getElementById('{{ form.category.vars.id }}');

    addCategoryBtn.addEventListener('click', async function() {
        const categoryName = newCategoryInput.value.trim();

        if (!categoryName) {
            alert('Veuillez saisir un nom de catégorie');
            return;
        }

        try {
            const response = await fetch('{{ path('app_category_api_create') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-CSRF-Token': '{{ csrf_token('category_create') }}'
                },
                body: JSON.stringify({ name: categoryName })
            });

            const data = await response.json();

            if (data.success) {
                // Ajouter la nouvelle catégorie au select
                const option = new Option(data.category.name, data.category.id);
                categorySelect.add(option);
                categorySelect.value = data.category.id;

                // Vider le champ et afficher un message de succès
                newCategoryInput.value = '';
                alert('Catégorie "' + data.category.name + '" ajoutée avec succès !');

                // Masquer la section d'ajout après succès
                document.querySelector('.category-add-section').style.display = 'none';
            } else {
                alert('Erreur: ' + data.message);
            }
        } catch (error) {
            console.error('Erreur:', error);
            alert('Une erreur est survenue lors de la création de la catégorie');
        }
    });

    // Afficher/masquer la section d'ajout selon la sélection
    categorySelect.addEventListener('change', function() {
        const addSection = document.querySelector('.category-add-section');
        if (this.value === '') {
            addSection.style.display = 'block';
        } else {
            addSection.style.display = 'none';
        }
    });

    // Masquer initialement la section d'ajout si une catégorie est déjà sélectionnée
    if (categorySelect.value !== '') {
        document.querySelector('.category-add-section').style.display = 'none';
    }
});
</script>
{% endblock %}
